---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "@fontsource/ibm-plex-mono/latin-400.css";
import "@fontsource/ibm-plex-mono/latin-600.css";
import "@fontsource/eczar/latin-800.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
<style is:global>
  :root {
    --background-color: #f6f6f4;
    --primary-dark: #0d0d0d;
    --background-color-brighter: #ffffff;

    --accent-base: 47, 91, 255;
    --accent: rgb(var(--accent-base));
    --accent-soft: rgba(var(--accent-base), 50%);
    --accent-softer: rgba(var(--accent-base), 15%);
  }
  html {
    font-family: "IBM Plex Mono", monospace;
    color: var(--primary-dark);
    background-color: var(--background-color);
    scroll-behavior: smooth;

    ::selection {
      background: var(--accent-soft);
      color: var(--background-color-brighter);
    }

    :focus {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
  }

  h1 {
    font-family: "Eczar";
    font-weight: 800;
    font-size: 3.5rem;
  }

  h2 {
    font-family: "Eczar";
    font-weight: 800;
    font-size: 2.5rem;
    margin-top: 2rem;
    margin-bottom: 0;
  }

  h3 {
    font-family: "Eczar";
    font-weight: 800;
    font-size: 1.5rem;
    margin: 0;
  }

  .csl-entry {
    margin-bottom: 0.7rem;
    font-size: 0.9rem;
    display: flex;
  }

  .csl-left-margin {
    margin-right: 0.5rem;
  }

  .csl-right-inline {
    width: 100%;
    overflow-wrap: anywhere;
  }

  p > a {
    background: var(--accent-softer);
    color: var(--accent);
    border-radius: 0.3rem;
    padding: 0.15em 0.45em;
  }

  a {
    text-decoration: none;
    color: var(--primary-dark);
    font-weight: 400;
  }

  a:hover {
    font-weight: 600;
  }

  .content-box {
    border: 5px solid rgba(0, 0, 0, 100%);
    background-color: var(--background-color-brighter);
    border-radius: 0.4rem;
    box-shadow: 0.5rem 0.5rem black;
    padding: 1.5rem;
  }
</style>
